---
import { PERSONAL_INFO } from "../data/personal";
import Section from "./SectionContainer.astro";
import Title from "./TitleSection.astro";
import Badge from "./Badge.astro";
---

<Section id="about" title="About Me" class="overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Photo Column -->
        <div
            class="relative group mx-auto drop-shadow-[8px_8px_0_#7836cf]"
            data-aos="fade-right"
        >
            <div class="absolute -inset-1 rounded-2xl"></div>
            <div class="relative">
                <img
                    src="/images/jhon-doe.png"
                    alt={`${PERSONAL_INFO.name} Portrait`}
                    class="rounded-2xl w-full max-w-sm object-cover"
                />
            </div>
        </div>

        <!-- Description Column -->
        <div class="flex flex-col gap-6" data-aos="fade-left">
            <Title level={3}>
                {PERSONAL_INFO.title}
            </Title>
            <p
                class="text-lg md:text-xl text-gray-300 leading-relaxed font-light"
            >
                Hola! Soy <span class="text-white font-semibold"
                    >{PERSONAL_INFO.name}</span
                >,
                {PERSONAL_INFO.description}
            </p>
            <p
                class="text-lg md:text-xl text-gray-300 leading-relaxed font-light"
            >
                {PERSONAL_INFO.journey}
            </p>
            
        </div>
    </div>
</Section>
